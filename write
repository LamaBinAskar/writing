import 'package:flutter/material.dart';
import '../services/ble_audio_service.dart';

class HomeScreen extends StatefulWidget {
  final BleAudioService bleService;

  const HomeScreen({super.key, required this.bleService});

  @override
  State<HomeScreen> createState() => _HomeScreenState();
}

class _HomeScreenState extends State<HomeScreen> {
  String _status = 'جاهز للاستماع...';
  String _lastDetection = '';
  final TextEditingController _keywordController = TextEditingController();

  @override
  void initState() {
    super.initState();
    widget.bleService.addListener(_updateUI);
  }

  void _updateUI() {
    setState(() {
      _status = widget.bleService.isListening
          ? 'يستمع...'
          : (widget.bleService.isConnected ? 'متصل' : 'غير متصل');

      _lastDetection =
          'انتظر إشارة من السوار'; // تقدرِين تربطينها لاحقًا بنتيجة YAMNet
    });
  }

  @override
  Widget build(BuildContext context) {
    final service = widget.bleService;

    return Scaffold(
      appBar: AppBar(
        title: const Text('PulseHear'),
        backgroundColor: const Color(0xFF71A39E),
        foregroundColor: Colors.white,
        actions: [
          IconButton(
            icon: Icon(
              service.isConnected
                  ? Icons.bluetooth_connected
                  : Icons.bluetooth,
            ),
            onPressed: () {
              if (service.isConnected) {
                service.disconnect();
              } else {
                service.connectToESP32('XIAO_ESP32S3');
              }
            },
          ),
        ],
      ),
      body: SingleChildScrollView(
        padding: const EdgeInsets.all(20),
        child: Column(
          crossAxisAlignment: CrossAxisAlignment.center,
          children: [
            const SizedBox(height: 20),
            const Icon(
              Icons.hearing_outlined,
              size: 120,
              color: Color(0xFF005352),
            ),
            const SizedBox(height: 30),
            Text(
              _status,
              style: const TextStyle(
                  fontSize: 24, fontWeight: FontWeight.bold),
            ),
            const SizedBox(height: 20),
            Container(
              padding: const EdgeInsets.all(15),
              decoration: BoxDecoration(
                color: Colors.grey[200],
                borderRadius: BorderRadius.circular(10),
              ),
              child: Text(
                _lastDetection,
                style: const TextStyle(fontSize: 18),
                textAlign: TextAlign.center,
              ),
            ),
            const SizedBox(height: 30),

            // قسم الكلمات المفتاحية (هنا بس UI، لسه ما ربطناه فعليًا بالخدمة)
            Card(
              color: const Color(0xFFF5F5F5),
              child: Padding(
                padding: const EdgeInsets.all(15),
                child: Column(
                  crossAxisAlignment: CrossAxisAlignment.start,
                  children: [
                    const Text(
                      'الكلمات المفتاحية',
                      style: TextStyle(
                          fontSize: 20, fontWeight: FontWeight.bold),
                    ),
                    const SizedBox(height: 10),
                    // TODO: اربطيها بـ keywords من BleAudioService لما تضيفينها هناك
                    const Text('سيتم ربطها لاحقًا بالخدمة'),
                    const SizedBox(height: 10),
                    Row(
                      children: [
                        Expanded(
                          child: TextField(
                            controller: _keywordController,
                            decoration: const InputDecoration(
                              hintText: 'أضف كلمة جديدة',
                              border: OutlineInputBorder(),
                            ),
                          ),
                        ),
                        const SizedBox(width: 10),
                        ElevatedButton(
                          onPressed: () {
                            _keywordController.clear();
                          },
                          style: ElevatedButton.styleFrom(
                            backgroundColor: const Color(0xFF005352),
                            foregroundColor: Colors.white,
                          ),
                          child: const Icon(Icons.add),
                        ),
                      ],
                    ),
                  ],
                ),
              ),
            ),

            const SizedBox(height: 20),

            ElevatedButton(
              onPressed: () async {
                await service.onDeviceSignal('adhan_detected');
              },
              style: ElevatedButton.styleFrom(
                backgroundColor: const Color(0xFF005352),
                foregroundColor: Colors.white,
                padding: const EdgeInsets.symmetric(
                    horizontal: 40, vertical: 15),
              ),
              child: const Text('اختبار YAMNet'),
            ),
          ],
        ),
      ),
    );
  }

  @override
  void dispose() {
    widget.bleService.removeListener(_updateUI);
    _keywordController.dispose();
    super.dispose();
  }
}
